{
  "name": "todo-app",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "concurrently \"pnpm --filter api-gateway dev\" \"pnpm --filter frontend dev\" \"pnpm --filter ai-service dev\"",
    "dev:all": "pnpm run dev",
    "lint": "turbo run lint",
    "clean": "turbo run clean && rimraf node_modules",
    "db:generate": "pnpm --filter @todo-app/shared db:generate",
    "db:push": "pnpm --filter @todo-app/shared db:push",
    "db:migrate": "pnpm --filter @todo-app/shared db:migrate",
    "db:studio": "pnpm --filter @todo-app/shared db:studio",
    "dev:frontend": "pnpm --filter frontend dev",
    "dev:api": "pnpm --filter api-gateway dev",
    "dev:ai": "pnpm --filter ai-service dev"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.22.0",
  "devDependencies": {
    "concurrently": "^9.2.1",
    "rimraf": "^6.1.2",
    "turbo": "^2.7.6"
  }
}